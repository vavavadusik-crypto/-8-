# Public frontend settings only.
# Do not put TikTok, YouTube, Instagram, OpenAI, or other secret API keys in frontend env vars.
VITE_APP_NAME=Hermest Board
VITE_DEFAULT_LANGUAGES=ru,en,de

# Future backend connector variables belong on a server, not inside the browser bundle:
SUPPORT_EMAIL=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
OPENAI_API_KEY=
OPENALEX_API_KEY=
GITHUB_TOKEN=

# Local/dev server-side JSON storage. In production this must be replaced by a
# durable database/blob adapter before private user data is stored server-side.
HERMEST_DATA_DIR=
HERMEST_ENABLE_DEMO_STORAGE=0
HERMEST_OWNER_TOKEN=
DATABASE_URL=
POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=
