{
  "name": "hermest-board",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Interactive AI-agent board for learning videos, scripts, roadmaps, voiceover, and publish packs.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "validate": "node scripts/validate.mjs",
    "audit:secrets": "node scripts/audit-secrets-file.mjs",
    "test:unit": "node --test test/unit/*.test.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke": "node scripts/smoke-render.mjs",
    "verify:live": "node scripts/live-verify.mjs",
    "render:project": "node scripts/render-project.mjs",
    "test:media": "node --test test/integration/render-project.test.mjs",
    "check": "npm run validate && npm run test:unit && npm run smoke:api && npm run test:media && npm run build && npm run smoke"
  },
  "devDependencies": {
    "vite": "^7.0.0"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
